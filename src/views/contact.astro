---
import Layout from "@/layouts/Layout.astro";

import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import InnerTitle from "@/components/sections/innerTitle.astro";
---

<Layout title={t('pages.contact.SEO.title')} description={t('pages.contact.SEO.description')} lang={lang}>
    <InnerTitle title={t('pages.contact.hero.title')} pageKeys={t('pages.contact.hero.pathkeys')} />
</Layout>
