---
import Layout from "@/layouts/Layout.astro";
import ProjectDetailCard from "@/components/sections/projects/projectDetail.astro";

const { project, prevProject, nextProject, lang } = Astro.props;
---

<Layout
    title={`${project.title} - Pau Segués Vitutia`}
    description={project.description}
    lang={lang}
>
    <ProjectDetailCard project={project} prevProject={prevProject} nextProject={nextProject} lang={lang} />
</Layout>
