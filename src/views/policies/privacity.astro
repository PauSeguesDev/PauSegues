---
/**
 * Privacy Policy View
 * Renders the localized privacy policy text in a highly legible layout.
 */
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import InnerTitle from "@/components/sections/InnerTitle.astro";
import Layout from "@/layouts/Layout.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get the structured sections from the translation file
const sections = t("pages.privacy.sections") as any[];
---

<Layout
  title={t("pages.privacy.SEO.title")}
  description={t("pages.privacy.SEO.description")}
  lang={lang}
>
  <InnerTitle 
    title={t('pages.privacy.hero.title')} 
    pageKeys={t('pages.privacy.hero.pathkeys')} 
  />

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <!-- Explanatory text cards -->
    <div class="space-y-12">
      {
        sections && Array.isArray(sections) && sections.map((section) => (
          <article class="p-6 sm:p-8 rounded-2xl bg-white/5 border border-white/10 hover:border-white/20 transition-all duration-300">
            <h2 class="text-xl sm:text-2xl font-bold text-white mb-4">
              {section.title}
            </h2>
            <div 
              class="text-sm sm:text-base text-white/80 leading-relaxed space-y-4"
              set:html={section.content}
            />
          </article>
        ))
      }
    </div>
  </section>
</Layout>