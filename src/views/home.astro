---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import Layout from "@/layouts/Layout.astro";

import Hero from "@/components/sections/home/hero.astro";
import WhoIAm from "@/components/sections/home/whoIAm.astro";
import Skills from '@/components/sections/home/skills.astro';
import ProjectsList from '@/components/sections/projects/projectsList.astro';
---

<Layout title={t('pages.home.SEO.title')} description={t('pages.home.SEO.description')} lang={lang}>
	<Hero />
	<WhoIAm />
	<ProjectsList limit={3} />
	<Skills />
</Layout>
