---
import ProjectView from '@/views/projectDetail.astro';
import es from '@/i18n/locales/es.json';

export function getStaticPaths() {
    const projects = es.projects.list;
    return projects.map((project, index) => {
        const prevProject = index < projects.length - 1 ? projects[index + 1] : null;
        const nextProject = index > 0 ? projects[index - 1] : null;
        return {
            params: { slug: project.slug },
            props: { project, prevProject, nextProject }
        };
    });
}

const { project, prevProject, nextProject } = Astro.props;
---
<ProjectView project={project} prevProject={prevProject} nextProject={nextProject} lang="es" />
