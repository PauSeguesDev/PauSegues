---
/**
 * Skills Card Component
 * Displays a group of technologies (icons + labels) wrapped in a 
 * "Mac-style" window UI container.
 */
interface Props {
    /** Category name (e.g., "Frontend", "Backend") */
    title: string;
    /** Array of skill objects containing the technology name and icon path */
    skills: { name: string; icon_url: string }[];
}

const { title, skills } = Astro.props;
---
<div class="bg-web-dark-blue rounded-xl overflow-hidden">
    <div class="relative flex items-center justify-center py-1 bg-web-pearl-blue">
        <div class="absolute left-4 flex gap-1">
            <span class="h-3 w-3 bg-red-500 rounded-full transition-colors"></span>
            <span class="h-3 w-3 bg-yellow-500 rounded-full transition-colors"></span>
            <span class="h-3 w-3 bg-green-500 rounded-full transition-colors"></span>
        </div>
        <h2 class="font-bold text-lg mr-4 text-web-dark-blue">{title}</h2>
    </div>

    <div class="p-8 grid grid-cols-4 gap-y-8 gap-x-4">
        {skills.map((skill: { name: string; icon_url: string }) => (
            <div class="flex flex-col items-center hover:scale-110 transition-all duration-300 space-y-2">
                <img 
                    src={skill.icon_url} 
                    alt={skill.name} 
                    width={60} 
                    height={60}
                    loading="lazy"
                />
                <p class="text-white text-sm text-center">{skill.name}</p>
            </div>
        ))}
    </div>
</div>