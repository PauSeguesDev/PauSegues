---
import { useTranslations } from "@/i18n/utils";

interface Props {
    project: {
        title: string;
        description: string;
        image: string;
        slug: string;
        externalUrl?: string;
    };
    lang: "ca" | "es" | "en";
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="bg-gradient pt-48 pb-32 -mt-24 relative overflow-hidden min-h-screen flex items-center">
    <!-- Background decorative elements -->
    <div
        class="absolute top-1/4 right-0 w-96 h-96 bg-web-pearl-blue/10 rounded-full blur-[120px] pointer-events-none animate-pulse"
    >
    </div>
    <div
        class="absolute bottom-1/4 left-0 w-96 h-96 bg-web-dark-blue/20 rounded-full blur-[150px] pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
            
            <!-- Left Column: Visuals -->
            <div class="lg:col-span-7 space-y-8 animate-fade-in-left">
                <!-- Back Action (Desktop only) -->
                <div class="hidden lg:block pt-4">
                    <a
                        href={`/${lang}/projects`}
                        onclick="if(window.history.length > 1) { history.back(); return false; }"
                        class="inline-flex items-center text-web-grey/60 hover:text-white transition-colors group cursor-pointer"
                    >
                        <div class="w-10 h-10 rounded-full border border-web-grey/20 flex items-center justify-center mr-4 group-hover:border-web-grey/50 transition-all group-hover:-translate-x-1">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                            </svg>
                        </div>
                        <span class="font-medium tracking-wide">{t('pages.projectDetail.back')}</span>
                    </a>
                </div>
                <!-- Main Project Image with premium frame -->
                <div class="relative group/img">
                    <div class="absolute -inset-1 bg-linear-to-r from-web-pearl-blue to-web-dark-blue rounded-3xl blur opacity-20 group-hover/img:opacity-40 transition duration-1000"></div>
                    <div class="relative overflow-hidden rounded-2xl border border-white/10 shadow-2xl aspect-video bg-web-night-blue">
                        <img 
                            src={project.image} 
                            alt={project.title}
                            class="w-full h-full object-cover transform scale-100 group-hover/img:scale-105 transition-transform duration-1000 ease-out"
                        />
                        <div class="absolute inset-0 bg-linear-to-t from-web-night-blue/60 via-transparent to-transparent opacity-60"></div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Details & Content -->
            <div class="lg:col-span-5 space-y-10 animate-fade-in-right">
                <div>
                    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-8 leading-tight">
                        {project.title}
                    </h1>
                    <p class="text-lg md:text-xl text-web-grey/80 font-light leading-relaxed">
                        {project.description}
                    </p>
                </div>

                <!-- CTAs -->
                <div class="flex flex-col sm:flex-row gap-6 pt-4">
                    {project.externalUrl && (
                        <a
                            href={project.externalUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="flex-1 group/btn relative inline-flex items-center justify-center px-8 py-5 text-base font-bold rounded-2xl text-web-night-blue bg-web-grey overflow-hidden transition-all hover:-translate-y-1 active:scale-95 cursor-pointer"
                        >
                            <span class="relative z-10 flex items-center gap-3">
                                {t('pages.projectDetail.visit')}
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover/btn:translate-x-1 group-hover/btn:-translate-y-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                                    <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                                </svg>
                            </span>
                        </a>
                    )}
                    
                    <!-- Mobile only Back button -->
                    <a
                        href={`/${lang}/projects`}
                        onclick="if(window.history.length > 1) { history.back(); return false; }"
                        class="lg:hidden flex items-center justify-center px-8 py-5 text-base font-semibold rounded-2xl text-web-grey border-2 border-white/10 hover:bg-white/5 transition-all cursor-pointer"
                    >
                        {t('pages.projectDetail.back')}
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .animate-fade-in-left {
        opacity: 0;
        animation: fade-in-left 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animate-fade-in-right {
        opacity: 0;
        animation: fade-in-right 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: 0.2s;
    }

    @keyframes fade-in-left {
        from { opacity: 0; transform: translateX(-30px); }
        to { opacity: 1; transform: translateX(0); }
    }
    @keyframes fade-in-right {
        from { opacity: 0; transform: translateX(30px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>