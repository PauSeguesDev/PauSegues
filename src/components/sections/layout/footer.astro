---
/**
 * Footer Component
 * Provides site navigation, social media presence, and legal links.
 * Integrated with i18n for multi-language support.
 */
import { SOCIAL } from "@/consts/social";
import { routes, navLabels } from "@/i18n/routes";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

// i18n initialization
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

/** * Legal Links Configuration
 * Defines the keys used to pull translated labels and routes.
 */
const footerLegalKeys = ['legal', 'privacy', 'cookies'] as const;

// Transform keys into an array of objects containing the localized text and URL
const legalLinks = footerLegalKeys.map((key) => ({
  text: navLabels[key][lang],
  href: routes[key][lang]
}));
---

<footer class="bg-web-dark-blue border-t border-white/10 text-white/80">
  <div class="flex flex-col md:flex-row justify-between items-center py-12 px-4 sm:px-12 md:px-24 lg:px-64 space-y-8 md:space-y-0">
    
    <div class="flex flex-col items-center md:items-start space-y-4 w-full md:w-1/3 text-center md:text-left">
      <img src="/images/logo.webp" alt="Logo" class="w-20 h-20" />
      <p class="text-sm leading-relaxed">
        {t('layout.footer.description')}
      </p>
    </div>

    <div class="flex flex-col items-center space-y-4 w-full md:w-1/3">
      <h3 class="font-semibold text-lg text-white">{t('layout.footer.socialTitle')}</h3>
      <ul class="flex flex-row space-x-4">
        {SOCIAL.map((social) => (
          <li class="flex items-center justify-center">
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:scale-110 hover:text-white transition-all duration-300 ease-out"
              aria-label={social.name}
            >
              <social.image.logo class="w-6 h-6 fill-current" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-white/5 mx-4 sm:mx-12 md:mx-24 lg:px-64"></div>

  <div class="flex flex-col md:flex-row justify-between items-center px-4 sm:px-12 md:px-24 lg:px-64 py-6 space-y-4 md:space-y-0 text-xs">
    <div>
      <p class="text-center md:text-left">
        &copy; {new Date().getFullYear()} Pau Segués Vitutia. {t('layout.footer.rights')}
      </p>
    </div>
    
    <nav class="flex justify-center items-center space-x-6">
      {legalLinks.map((link) => (
        <a href={link.href} class="hover:text-white hover:underline transition-colors">
          {link.text}
        </a>
      ))}
    </nav>
  </div>
</footer>