---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="w-full min-h-[70dvh] flex items-center">
    <div class="flex flex-col md:flex-row items-center justify-center w-full px-4 sm:px-12 md:px-24 lg:px-64 py-8 gap-8 md:gap-24">
        <div class="flex-1 flex flex-col justify-center gap-2">
            <h2 class="text-3xl font-bold">{t('pages.home.presentation.subtitle')}</h2>
            {
                t('pages.home.presentation.paragrafs').map((paragraph: string) => (
                    <p set:html={paragraph}></p>
                ))
            }
        </div>
        <div class="flex-1 flex justify-center">
            <img 
                src={t('pages.home.presentation.image.src')} 
                alt={t('pages.home.presentation.image.alt')} 
                class="max-h-[60dvh] w-auto rounded-2xl object-cover"
            />
        </div>
    </div>
</section>