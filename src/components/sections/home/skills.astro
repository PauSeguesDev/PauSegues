---
import { SKILLS } from "@/consts/skills";
import SkillsCard from "@/components/skillsCard.astro";

import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

---

<section class="my-8">
    <div class="flex justify-center items-center mb-10">
        <h2 class="text-3xl font-bold">{t('pages.home.skills.sectiontitle')}</h2>
    </div>
    <div class="flex justify-center items-start gap-4">
        <div class="grid grid-cols-2 gap-8">
            {
                SKILLS.map((group) => (
                    <SkillsCard title={t(`pages.home.skills.titlelist.${group.name.toLowerCase()}`)} skills={group.skills} />
                ))
            }
        </div>
    </div>
</section>
