---
/**
 * Project Card Component
 * A visually rich link card used to showcase portfolio projects.
 * Features a zoom-on-hover effect and a bottom-aligned title overlay.
 */
interface Props {
    /** The title of the project to be displayed on the card */
    title: string;
    /** The source URL for the project's preview image */
    image: string;
    /** The destination URL (external or internal) */
    link: string;
}

const { title, image, link } = Astro.props;
---

<a 
    href={link}
    class="group relative block w-full aspect-video overflow-hidden rounded-2xl bg-web-dark-blue shadow-lg transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
>
    <div class="h-full w-full overflow-hidden">
        <img 
            src={image} 
            alt={title} 
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
    </div>

    <div class="absolute inset-0 bg-linear-to-t from-web-night-blue/90 via-web-night-blue/20 to-transparent flex items-end p-6">
        <h3 class="text-web-grey text-xl md:text-2xl font-bold transition-transform duration-300 group-hover:translate-x-2">
            {title}
        </h3>
    </div>
</a>