---
interface Props {
  id: string;
}
const { id } = Astro.props;
---

<button id={id} class="group flex flex-col justify-center items-center w-10 h-10 space-y-1.5 z-50 focus:outline-none">
  <span class="block w-8 h-0.5 bg-white transition-all duration-300 ease-out group-[.is-active]:rotate-45 group-[.is-active]:translate-y-2"></span>
  <span class="block w-8 h-0.5 bg-white transition-all duration-300 ease-out group-[.is-active]:opacity-0"></span>
  <span class="block w-8 h-0.5 bg-white transition-all duration-300 ease-out group-[.is-active]:-rotate-45 group-[.is-active]:translate-y-[-8px]"></span>
</button>