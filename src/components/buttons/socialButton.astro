---
/**
 * Social Icon Component
 * Dynamically renders a social media link with its corresponding SVG logo.
 */
import type { SocialType } from "@/consts/social";

interface Props {
    /** The social object containing URL, name, and the logo component */
    social: SocialType;
}
const { social } = Astro.props;
---
<a 
    href={social.url} 
    target="_blank" 
    rel="noopener noreferrer" 
    class="p-4 bg-web-dark-blue/20 border border-web-pearl-blue/10 rounded-2xl text-web-pearl-blue hover:text-white hover:bg-web-dark-blue/40 hover:border-web-pearl-blue/30 transition-all group"
        aria-label={social.label ?? social.name}
    >
        <social.image.logo class="w-6 h-6 fill-current group-hover:scale-110 transition-transform" />
    </a>