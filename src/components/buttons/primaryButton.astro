---
/**
 * PrimaryButton component
 * A versatile button component that supports both links and button actions.
 * Features a premium design with hover animations and slot support for icons.
 */
interface Props {
    /** The label displayed inside the button (optional if using slot) */
    Text?: string;
    /** The URL the button points to (only for type="link") */
    Link?: string;
    /** Optional: Specifies where to open the linked document (e.g., '_blank') */
    target?: string;
    /** Optional: Specifies the relationship between the current and linked document */
    rel?: string;
    /** The type of button: 'link' (default), 'submit', or 'button' */
    type?: "link" | "submit" | "button";
    /** Optional: Unique identifier for the element */
    id?: string;
    /** Optional: Additional CSS classes to append */
    classes?: string;
}

const { Text, Link, target, rel, type = "link", id, classes = "" } = Astro.props;

/**
 * Styling
 * Standardized premium style based on the project detail design.
 */
const baseClasses = "group/btn relative inline-flex items-center justify-center px-8 py-5 text-base font-bold rounded-2xl text-web-night-blue bg-web-grey overflow-hidden transition-all active:scale-95 disabled:opacity-50 disabled:translate-y-0 shadow-lg shadow-web-dark-blue/10 cursor-pointer hover:scale-105 transition-transform duration-500 ease-out";
const combinedClasses = `${baseClasses} ${classes}`;
---

{type === "link" ? (
    <a
        href={Link}
        target={target}
        rel={rel}
        id={id}
        class={combinedClasses}
    >
        <span class="relative z-10 flex items-center gap-1">
            {Text}
            <slot />
        </span>
    </a>
) : (
    <button
        type={type as "submit" | "button"}
        id={id}
        class={combinedClasses}
    >
        <span class="relative z-10 flex items-center gap-1">
            {Text}
            <slot />
        </span>
    </button>
)}
